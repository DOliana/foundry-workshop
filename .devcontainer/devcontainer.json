// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Python 3.11, functions, jupyter",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",
	"features": {
		"ghcr.io/devcontainers/features/azure-cli:latest": {
			"installBicep": true,
			"version": "latest",
			"bicepVersion": "latest"
		},
		// Preserve ~/.azure folder across container instances (avoids needing to login after rebuilding)
		"ghcr.io/azure/azure-dev/azd:latest": {
			"version": "stable"
		},
		"ghcr.io/jlaundry/devcontainer-features/azure-functions-core-tools:1": {
			"version": "latest"
		}
	},

	// Workaround for pip 24.0 ensurepip AssertionError on overlayfs-backed
	// dev container workspaces (pyc bytecode compile step is skipped, tripping
	// an internal assert). Disabling bytecode compilation during pip installs
	// lets `python -m venv .venv` succeed.
	"remoteEnv": {
		"PIP_NO_COMPILE": "1"
	},

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "PIP_NO_COMPILE=1 pip install --upgrade pip && pip install uv",
	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.flake8",
				"ms-python.autopep8",
				"yzhang.markdown-all-in-one",
				"ms-python.python",
				"ms-vscode.vscode-node-azure-pack"
			]
		}
	}
}
