// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Python 3.11, functions, jupyter",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",
	"features": {
		"ghcr.io/devcontainers/features/azure-cli:latest": {
			"installBicep": true,
			"version": "latest",
			"bicepVersion": "latest"
		},
		// Preserve ~/.azure folder across container instances (avoids needing to login after rebuilding)
		"ghcr.io/azure/azure-dev/azd:latest": {
			"version": "stable"
		},
		"ghcr.io/jlaundry/devcontainer-features/azure-functions-core-tools:1": {
			"version": "latest"
		}
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "pip install --upgrade pip && pip install ipykernel jupyter ipywidgets --upgrade",
	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.flake8",
				"ms-python.autopep8",
				"yzhang.markdown-all-in-one",
				"ms-python.python",
				"ms-vscode.vscode-node-azure-pack"
			]
		}
	}

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
