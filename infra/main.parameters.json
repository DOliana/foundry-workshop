{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION=swedencentral}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "defaultModelCapacity": {
      "value": "${DEFAULT_MODEL_CAPACITY=50}"
    },
    "defaultModelName": {
      "value": "${DEFAULT_MODEL_NAME=gpt-5-mini}"
    },
    "defaultModelVersion": {
      "value": "${DEFAULT_MODEL_VERSION=2025-08-07}"
    },
    "embeddingModelName": {
      "value": "${EMBEDDING_MODEL_NAME=text-embedding-3-small}"
    },
    "embeddingModelVersion": {
      "value": "${EMBEDDING_MODEL_VERSION=1}"
    },
    "embeddingModelCapacity": {
      "value": "${EMBEDDING_MODEL_CAPACITY=30}"
    },
    "deployRealtimeModel": {
      "value": "${DEPLOY_REALTIME_MODEL=false}"
    }
  }
}
